{
  "college_info": {
    "name": "Majlis Polytechnic College",
    "vision": "To be a center of excellence in technical education, molding professionals with ethical values and social commitment.",
    "mission": [
      "Provide quality technical education.",
      "Inculcate ethical values and leadership qualities.",
      "Foster industry-institute interaction.",
      "Empower students for lifelong learning."
    ],
    "about": "Majlis Polytechnic College is a premier institution dedicated to providing high-quality technical education. We offer state-of-the-art facilities and a conducive learning environment.",
    "contact": {
      "phone": "+91 8281899825",
      "email": "info@majliscomplex.org",
      "address": "Majlis Nagar, Puramannur (P O), Moorkanad, Valanchery, Malappuram Dist, Kerala - 676552",
      "portals": {
        "fees_linways": "https://majlispolytechnic.linways.com/",
        "admission_portal": "https://polyadmission.org/let/index.php?r=site%2Fhome"
      }
    }
  },
  "facilities": {
    "hostel": {
      "available": true,
      "type": "Girls only",
      "description": "Safe and secure hostel facilities provided exclusively for girl students with modern amenities."
    },
    "bus_routes": [
      "Tirur",
